{
  "name": "fallen-empire",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3010",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "generate-biomes": "python3 scripts/generate_biome_overlays.py",
    "sim-combat-length": "npx ts-node --transpile-only -r tsconfig-paths/register --project tsconfig.train.json scripts/sim-combat-length.ts",
    "train-ai": "npx ts-node -r tsconfig-paths/register --project tsconfig.train.json scripts/train-ai.ts",
    "diag-sim-health": "npx ts-node -r tsconfig-paths/register --project tsconfig.train.json scripts/diag-sim-health.ts",
    "audit-strategy-flow": "npx ts-node -r tsconfig-paths/register --project tsconfig.train.json scripts/audit-strategy-flow.ts",
    "tournament-league": "npx ts-node -r tsconfig-paths/register --project tsconfig.train.json scripts/tournament-league.ts",
    "optimize-trends": "npx ts-node -r tsconfig-paths/register --project tsconfig.train.json scripts/optimize-trends.ts",
    "validate-robustness": "npx ts-node -r tsconfig-paths/register --project tsconfig.train.json scripts/validate-robustness.ts",
    "seasonal-sim": "npx ts-node -r tsconfig-paths/register --project tsconfig.train.json scripts/seasonal-sim.ts",
    "regression-harness": "npx ts-node -r tsconfig-paths/register --project tsconfig.train.json scripts/regression-harness.ts",
    "validate-ai-params": "npx ts-node -r tsconfig-paths/register --project tsconfig.train.json scripts/validate-ai-params.ts",
    "train-ai-overnight": "bash scripts/overnight-train.sh"
  },
  "dependencies": {
    "@react-three/drei": "^9.108.0",
    "@react-three/fiber": "^8.16.0",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "simplex-noise": "^4.0.1",
    "three": "^0.165.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.165.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
