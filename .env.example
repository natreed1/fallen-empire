# ─── Optional site password gate ───
# Production: defaults are built in (see src/lib/siteAuth.ts). Set these to override password / cookie signing.
# Local dev: set BOTH to test /login; if unset, the app stays open.
#
# SITE_PASSWORD=your-shared-secret
# COOKIE_SECRET=long-random-string-use-openssl-rand-hex-32

SITE_PASSWORD=
COOKIE_SECRET=
