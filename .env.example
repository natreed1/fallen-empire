# ─── Optional site password gate (private deploy) ───
# If BOTH are set, visitors must POST the password to /api/auth (login page at /login)
# before accessing the game. If either is unset, the site stays open (typical local dev).
#
# SITE_PASSWORD=your-shared-secret
# COOKIE_SECRET=long-random-string-use-openssl-rand-hex-32

SITE_PASSWORD=
COOKIE_SECRET=
